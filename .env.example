VITE_TMDB_KEY=your_tmdb_api_key_here
VITE_APP_API=https://<app-api-id>.execute-api.<region>.amazonaws.com/prod
VITE_AUTH_API=https://<auth-api-id>.execute-api.<region>.amazonaws.com/prod

# Copy this file to .env and fill in the values before running the app.
# .env is gitignored and will not be committed to the repository.
# VITE_APP_API and VITE_AUTH_API are the CDK deploy output URLs from Assignment 1. 